# Copy to .env and fill in.

# Anthropic — the brain for both agents
ANTHROPIC_API_KEY=

# Guild AI — NO API KEY HERE. The CLI authenticates via browser:
#   npm i @guildai/cli -g && guild auth login
# The code shells out to the already-logged-in `guild`. Just set:
GUILD_WORKSPACE_ID=
# ID of the victim agent (from `guild agent get` after `guild agent init`)
TRIAGEBOT_AGENT_ID=

# Senso / cited.md publishing
SENSO_API_KEY=

# ClickHouse (optional telemetry — cut if behind)
CLICKHOUSE_URL=
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=

# --- The fork that decides whether we have the WINNING demo or the SAFE one ---
# Set to "runtime-deny" if guild_credentials_request is interceptable (block attack live).
# Set to "cli-disable" for the guaranteed fallback (detect, then disable the agent).
# Confirm which in the first 30 minutes at the venue.
CONTAINMENT_MODE=cli-disable
