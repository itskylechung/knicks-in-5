# Copy to .env and fill in.

# Anthropic — the brain for both agents
ANTHROPIC_API_KEY=

# Guild AI — NO API KEY HERE. The CLI authenticates via browser:
#   npm i @guildai/cli -g && guild auth login
# The code shells out to the already-logged-in `guild`. Just set:
GUILD_WORKSPACE_ID=
# ID of the victim agent (from `guild agent get` after `guild agent init`)
TRIAGEBOT_AGENT_ID=

# Senso / cited.md publishing — postmortems publish via the authenticated `senso`
# CLI (`senso login`). SENSO_API_KEY is optional here; the CLI owns auth.
SENSO_API_KEY=
# Optional: override the GEO question postmortems answer on cited.md.
# SENSO_GEO_QUESTION_ID=

# ClickHouse (optional telemetry dashboard)
CLICKHOUSE_URL=
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=

# --- Containment mode ---
# "runtime-deny" — deny the hijacked credential request live (block the attack).
# "cli-disable"  — detect the deviation, then remove the agent from its workspace.
CONTAINMENT_MODE=cli-disable

# --- Monetization (x402) ---
# "sim"  = real x402 protocol against a local facilitator, on-chain settle simulated
#          (zero setup; `npm run pay-demo` just works).
# "live" = real on-chain settlement on Base Sepolia (needs a funded buyer wallet
#          and a real X402_FACILITATOR_URL, e.g. https://x402.org/facilitator).
PAYMENT_MODE=sim
PAYMENT_NETWORK=base-sepolia
AUDIT_PRICE=$0.05
# Where AgentSOC receives payment (any address is fine in sim mode).
# PAYMENT_RECEIVER=0xYourReceivingAddress
# X402_FACILITATOR_URL=https://x402.org/facilitator
# Public URL of the paid /audit API, embedded in the cited.md call-to-action.
# INTEL_API_PUBLIC_URL=https://your-deployment.example.com
# Buyer wallet for live on-chain payment (fund with testnet USDC). Sim generates one.
# BUYER_PRIVATE_KEY=0x...
